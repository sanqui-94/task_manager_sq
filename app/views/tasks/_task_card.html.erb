<%= link_to task_path(task), class: "block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition hover:border-gray-300 hover:shadow-md" do %>
  <div class="mb-2 flex items-center justify-between gap-2">
    <span class="font-mono text-xs text-gray-500"><%= task.code %></span>
    <%= render "shared/priority_badge", priority: task.priority %>
  </div>
  <h3 class="font-medium text-gray-900"><%= task.title %></h3>
<% end %>
