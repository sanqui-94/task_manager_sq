<% content_for :title, "Archive" %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Archive</h1>
  <p class="mt-1 text-sm text-gray-600">Archived tasks are hidden from the board but remain accessible here.</p>
</div>

<% if @tasks.any? %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <ul class="divide-y divide-gray-200">
      <% @tasks.each do |task| %>
        <li class="flex flex-col gap-3 p-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0 flex-1">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class="font-mono text-xs text-gray-500"><%= task.code %></span>
              <%= render "shared/priority_badge", priority: task.priority %>
              <span class="text-xs text-gray-500">Archived <%= time_ago_in_words(task.archived_at) %> ago</span>
            </div>
            <%= link_to task.title, task_path(task), class: "font-medium text-gray-900 hover:text-blue-600" %>
          </div>

          <div class="flex gap-2">
            <%= link_to "View", task_path(task), class: "rounded-md bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200" %>
            <%= button_to "Unarchive", unarchive_task_path(task), method: :patch, class: "rounded-md bg-green-100 px-3 py-2 text-sm font-medium text-green-800 hover:bg-green-200" %>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
<% else %>
  <div class="rounded-xl border border-dashed border-gray-300 bg-white p-10 text-center">
    <p class="text-sm text-gray-500">No archived tasks yet.</p>
    <%= link_to "Go to board", root_path, class: "mt-4 inline-block text-sm font-medium text-blue-600 hover:text-blue-500" %>
  </div>
<% end %>
